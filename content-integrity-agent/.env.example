# Content Integrity Agent - Environment Configuration
# Copy this file to .env and fill in your values

# Required: OpenRouter API key for LLM suggestions
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: OpenRouter model selection
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: LLM temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.3

# Optional: Confidence thresholds for routing
AUTO_FIX_THRESHOLD=0.90
NOTIFY_THRESHOLD=0.60

# Optional: HTTP timeout in seconds
HTTP_TIMEOUT=15

# Optional: Enable/disable LLM (fallback to deterministic matching if false)
ENABLE_LLM=true

# Optional: Cache directory
CACHE_DIR=.cache

# Optional: Fixtures directory
FIXTURES_DIR=fixtures

# Optional: Dry run mode (true = print only, false = would send actual notifications)
DRY_RUN=true

# Optional: Site metadata for OpenRouter API
SITE_URL=https://canonical.com
SITE_NAME=Content Integrity Agent

# Optional: Google service account credentials for reading copydocs
# Paste the full JSON key of a service account with Documents and Drive read scopes
GOOGLE_SERVICE_ACCOUNT_INFO={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}